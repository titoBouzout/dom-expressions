{
  "compilerOptions": {
    "outDir": "types",
    "emitDeclarationOnly": true,
    "declaration": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "paths": {
      "dom-expressions/*": ["../dom-expressions/*"]
    }
  },
  "include": ["src"]
}
